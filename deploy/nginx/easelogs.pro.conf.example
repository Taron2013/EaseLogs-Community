# EaseLogs Pro — local intranet nginx example
#
# Install:
#   sudo cp deploy/nginx/easelogs.pro.conf.example /etc/nginx/conf.d/easelogs.pro.conf
#   sudo nginx -t && sudo systemctl reload nginx
#
# TLS (mkcert example):
#   mkcert easelogs.pro
#   sudo mkdir -p /etc/nginx/certs/easelog-pro
#   sudo install -m 644 easelogs.pro.pem /etc/nginx/certs/easelog-pro/
#   sudo install -m 600 easelogs.pro-key.pem /etc/nginx/certs/easelog-pro/
#   Adjust ssl_certificate paths below to match your cert filenames.
#
# Hosts (workstation):
#   127.0.0.1 easelogs.pro
#
# Hosts (phone/tablet on LAN — replace with your workstation IP):
#   192.168.x.x easelogs.pro

server {
    listen 80;
    server_name easelogs.pro;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name easelogs.pro;
    client_max_body_size 25M;

    ssl_certificate /etc/nginx/certs/easelog-pro/easelogs.pro.pem;
    ssl_certificate_key /etc/nginx/certs/easelog-pro/easelogs.pro-key.pem;

    root /var/www/projects/easelog-pro/public;
    index index.php index.html;

    access_log /var/log/nginx/easelog-pro.access.log;
    error_log /var/log/nginx/easelog-pro.error.log;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php-fpm/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_index index.php;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
