# Example production-style .env for local Pro intranet (/var/www/projects/easelog-pro)
# Copy manually if not using first-time seed from Community.
#
#   cp deploy/env/easelog-pro.env.example /var/www/projects/easelog-pro/.env
#   cd /var/www/projects/easelog-pro && php artisan key:generate

APP_NAME="EaseLogs Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://easelogs.pro

EASELOGS_EDITION=Pro

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
